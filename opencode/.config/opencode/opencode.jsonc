{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "permission": {
    "bash": {
      "*": "ask",
      "rm *": "deny",
      "ls *": "allow",
      "find *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "tree *": "allow",
      "dirname *": "allow",
      "xargs *": "allow",
      "echo *": "allow",
    },
    "skill": "allow",
    "context7": "allow",
  },
}

// vim: ts=2 sw=2
